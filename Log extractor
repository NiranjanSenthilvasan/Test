import argparse
import csv
import json
from pathlib import Path
from typing import Any


TOKEN_KEYWORDS = {
    "input_tokens",
    "output_tokens",
    "prompt_tokens",
    "completion_tokens",
    "total_tokens",
    "llm.token_count.prompt",
    "llm.token_count.completion",
    "gen_ai.usage.input_tokens",
    "gen_ai.usage.output_tokens",
}

ERROR_KEYWORDS = {
    "error",
    "error.message",
    "exception.message",
    "exception.type",
    "exception.stacktrace",
    "status.code",
    "otel.status_code",
}

HTTP_KEYWORDS = {
    "http.method",
    "http.request.method",
    "http.url",
    "url.full",
    "http.status_code",
    "http.response.status_code",
    "server.address",
}

MODEL_KEYWORDS = {
    "model",
    "model.name",
    "llm.model_name",
    "gen_ai.request.model",
    "gen_ai.response.model",
    "gen_ai.system",
}

TOOL_KEYWORDS = {
    "tool",
    "tool.name",
    "tool.id",
    "tool.description",
    "gen_ai.tool.name",
}


def load_json(file_path: Path) -> dict[str, Any]:
    try:
        with file_path.open("r", encoding="utf-8") as file:
            return json.load(file)
    except FileNotFoundError as exc:
        raise RuntimeError(f"File not found: {file_path}") from exc
    except json.JSONDecodeError as exc:
        raise RuntimeError(
            f"Invalid JSON at line {exc.lineno}, column {exc.colno}: {exc.msg}"
        ) from exc


def tag_value(tag: dict[str, Any]) -> Any:
    """
    Jaeger tags commonly look like:
    {
        "key": "agent.name",
        "type": "string",
        "value": "gdr_offer_agent_v2"
    }
    """
    return tag.get("value")


def tags_to_dict(tags: list[dict[str, Any]] | None) -> dict[str, Any]:
    output: dict[str, Any] = {}

    for tag in tags or []:
        key = tag.get("key")
        if key:
            output[str(key)] = tag_value(tag)

    return output


def process_tags_to_dict(
    process: dict[str, Any] | None,
) -> dict[str, Any]:
    if not process:
        return {}

    return tags_to_dict(process.get("tags"))


def duration_ms(duration_microseconds: int | float | None) -> float:
    if not duration_microseconds:
        return 0.0

    return round(float(duration_microseconds) / 1000, 3)


def start_time_ms(start_time_microseconds: int | float | None) -> float:
    if not start_time_microseconds:
        return 0.0

    return float(start_time_microseconds) / 1000


def find_matching_attributes(
    attributes: dict[str, Any],
    keywords: set[str],
) -> dict[str, Any]:
    matches: dict[str, Any] = {}

    for key, value in attributes.items():
        normalized_key = key.lower()

        if (
            normalized_key in keywords
            or any(keyword in normalized_key for keyword in keywords)
        ):
            matches[key] = value

    return matches


def get_parent_span_id(span: dict[str, Any]) -> str | None:
    for reference in span.get("references", []):
        if reference.get("refType") == "CHILD_OF":
            return reference.get("spanID")

    return None


def extract_logs(span: dict[str, Any]) -> list[dict[str, Any]]:
    extracted_logs: list[dict[str, Any]] = []

    for log in span.get("logs", []):
        fields = tags_to_dict(log.get("fields"))
        extracted_logs.append(
            {
                "timestamp": log.get("timestamp"),
                "fields": fields,
            }
        )

    return extracted_logs


def extract_error_information(
    span_tags: dict[str, Any],
    logs: list[dict[str, Any]],
) -> list[str]:
    errors: list[str] = []

    for key, value in span_tags.items():
        normalized_key = key.lower()

        if normalized_key in ERROR_KEYWORDS or any(
            error_key in normalized_key for error_key in ERROR_KEYWORDS
        ):
            value_string = str(value)

            if normalized_key in {"status.code", "otel.status_code"}:
                if value_string.upper() not in {"OK", "UNSET", "0"}:
                    errors.append(f"{key}: {value}")
            elif normalized_key == "error":
                if value in {True, "true", "True", 1, "1"}:
                    errors.append(f"{key}: {value}")
            else:
                errors.append(f"{key}: {value}")

    for log in logs:
        fields = log["fields"]

        for key, value in fields.items():
            normalized_key = key.lower()

            if (
                "exception" in normalized_key
                or "error" in normalized_key
                or normalized_key == "event"
                and str(value).lower() == "exception"
            ):
                errors.append(f"log.{key}: {value}")

    return list(dict.fromkeys(errors))


def extract_trace_data(
    trace_json: dict[str, Any],
) -> list[dict[str, Any]]:
    traces = trace_json.get("data", [])

    if not isinstance(traces, list):
        raise RuntimeError("Expected 'data' to be a list of traces.")

    extracted_spans: list[dict[str, Any]] = []

    for trace in traces:
        trace_id = trace.get("traceID")
        processes = trace.get("processes", {})

        for span in trace.get("spans", []):
            span_tags = tags_to_dict(span.get("tags"))
            logs = extract_logs(span)

            process_id = span.get("processID")
            process = processes.get(process_id, {})
            process_tags = process_tags_to_dict(process)

            combined_attributes = {
                **process_tags,
                **span_tags,
            }

            token_info = find_matching_attributes(
                combined_attributes,
                TOKEN_KEYWORDS,
            )
            http_info = find_matching_attributes(
                combined_attributes,
                HTTP_KEYWORDS,
            )
            model_info = find_matching_attributes(
                combined_attributes,
                MODEL_KEYWORDS,
            )
            tool_info = find_matching_attributes(
                combined_attributes,
                TOOL_KEYWORDS,
            )

            errors = extract_error_information(span_tags, logs)

            extracted_spans.append(
                {
                    "trace_id": trace_id or span.get("traceID"),
                    "span_id": span.get("spanID"),
                    "parent_span_id": get_parent_span_id(span),
                    "operation_name": span.get("operationName"),
                    "start_time_us": span.get("startTime"),
                    "start_time_ms": start_time_ms(span.get("startTime")),
                    "duration_us": span.get("duration", 0),
                    "duration_ms": duration_ms(span.get("duration")),
                    "process_id": process_id,
                    "service_name": process.get("serviceName"),
                    "agent_name": combined_attributes.get("agent.name"),
                    "agent_id": combined_attributes.get("agent.id"),
                    "framework": combined_attributes.get("framework"),
                    "session_id": combined_attributes.get("session.id"),
                    "tool_info": tool_info,
                    "model_info": model_info,
                    "token_info": token_info,
                    "http_info": http_info,
                    "errors": errors,
                    "logs": logs,
                    "all_tags": span_tags,
                }
            )

    return sorted(
        extracted_spans,
        key=lambda span: span["start_time_us"] or 0,
    )


def build_span_tree(
    spans: list[dict[str, Any]],
) -> tuple[list[dict[str, Any]], dict[str, list[dict[str, Any]]]]:
    roots: list[dict[str, Any]] = []
    children: dict[str, list[dict[str, Any]]] = {}

    span_ids = {span["span_id"] for span in spans}

    for span in spans:
        parent_id = span["parent_span_id"]

        if parent_id and parent_id in span_ids:
            children.setdefault(parent_id, []).append(span)
        else:
            roots.append(span)

    for child_list in children.values():
        child_list.sort(key=lambda item: item["start_time_us"] or 0)

    roots.sort(key=lambda item: item["start_time_us"] or 0)

    return roots, children


def print_span_tree(
    span: dict[str, Any],
    children: dict[str, list[dict[str, Any]]],
    depth: int = 0,
) -> None:
    indent = "  " * depth
    error_indicator = " ERROR" if span["errors"] else ""

    print(
        f"{indent}- {span['operation_name']} "
        f"({span['duration_ms']} ms){error_indicator}"
    )

    if span["tool_info"]:
        print(f"{indent}  Tool: {span['tool_info']}")

    if span["model_info"]:
        print(f"{indent}  Model: {span['model_info']}")

    if span["token_info"]:
        print(f"{indent}  Tokens: {span['token_info']}")

    if span["http_info"]:
        print(f"{indent}  HTTP: {span['http_info']}")

    for error in span["errors"]:
        print(f"{indent}  Error: {error}")

    for child in children.get(span["span_id"], []):
        print_span_tree(child, children, depth + 1)


def calculate_token_totals(
    spans: list[dict[str, Any]],
) -> dict[str, float]:
    totals = {
        "input_tokens": 0,
        "output_tokens": 0,
        "total_tokens": 0,
    }

    for span in spans:
        for key, value in span["token_info"].items():
            try:
                numeric_value = float(value)
            except (TypeError, ValueError):
                continue

            normalized_key = key.lower()

            if "input" in normalized_key or "prompt" in normalized_key:
                totals["input_tokens"] += numeric_value

            elif "output" in normalized_key or "completion" in normalized_key:
                totals["output_tokens"] += numeric_value

            elif "total" in normalized_key:
                totals["total_tokens"] += numeric_value

    if totals["total_tokens"] == 0:
        totals["total_tokens"] = (
            totals["input_tokens"] + totals["output_tokens"]
        )

    return totals


def print_summary(spans: list[dict[str, Any]], top_n: int = 10) -> None:
    if not spans:
        print("No spans found.")
        return

    roots, children = build_span_tree(spans)
    token_totals = calculate_token_totals(spans)

    traces = {span["trace_id"] for span in spans}
    errors = [span for span in spans if span["errors"]]
    tool_spans = [span for span in spans if span["tool_info"]]
    http_spans = [span for span in spans if span["http_info"]]
    model_spans = [span for span in spans if span["model_info"]]

    slowest = sorted(
        spans,
        key=lambda span: span["duration_ms"],
        reverse=True,
    )[:top_n]

    print("\n========== TRACE SUMMARY ==========")
    print(f"Trace count       : {len(traces)}")
    print(f"Span count        : {len(spans)}")
    print(f"Tool-related spans: {len(tool_spans)}")
    print(f"Model-related spans: {len(model_spans)}")
    print(f"HTTP-related spans: {len(http_spans)}")
    print(f"Error spans       : {len(errors)}")

    agent_names = {
        span["agent_name"]
        for span in spans
        if span["agent_name"]
    }

    frameworks = {
        span["framework"]
        for span in spans
        if span["framework"]
    }

    print(f"Agents            : {', '.join(agent_names) or 'Not captured'}")
    print(f"Frameworks        : {', '.join(frameworks) or 'Not captured'}")

    print("\nToken totals:")
    print(f"  Input tokens : {int(token_totals['input_tokens'])}")
    print(f"  Output tokens: {int(token_totals['output_tokens'])}")
    print(f"  Total tokens : {int(token_totals['total_tokens'])}")

    print("\n========== EXECUTION FLOW ==========")

    for root in roots:
        print_span_tree(root, children)

    print("\n========== SLOWEST OPERATIONS ==========")

    for index, span in enumerate(slowest, start=1):
        print(
            f"{index:>2}. {span['operation_name']:<50} "
            f"{span['duration_ms']:>12.3f} ms"
        )

    if errors:
        print("\n========== ERRORS ==========")

        for span in errors:
            print(f"\nOperation: {span['operation_name']}")

            for error in span["errors"]:
                print(f"  - {error}")


def save_csv(
    spans: list[dict[str, Any]],
    output_path: Path,
) -> None:
    columns = [
        "trace_id",
        "span_id",
        "parent_span_id",
        "operation_name",
        "duration_ms",
        "service_name",
        "agent_name",
        "framework",
        "session_id",
        "tool_info",
        "model_info",
        "token_info",
        "http_info",
        "errors",
    ]

    with output_path.open(
        "w",
        newline="",
        encoding="utf-8",
    ) as file:
        writer = csv.DictWriter(file, fieldnames=columns)
        writer.writeheader()

        for span in spans:
            writer.writerow(
                {
                    "trace_id": span["trace_id"],
                    "span_id": span["span_id"],
                    "parent_span_id": span["parent_span_id"],
                    "operation_name": span["operation_name"],
                    "duration_ms": span["duration_ms"],
                    "service_name": span["service_name"],
                    "agent_name": span["agent_name"],
                    "framework": span["framework"],
                    "session_id": span["session_id"],
                    "tool_info": json.dumps(
                        span["tool_info"],
                        ensure_ascii=False,
                    ),
                    "model_info": json.dumps(
                        span["model_info"],
                        ensure_ascii=False,
                    ),
                    "token_info": json.dumps(
                        span["token_info"],
                        ensure_ascii=False,
                    ),
                    "http_info": json.dumps(
                        span["http_info"],
                        ensure_ascii=False,
                    ),
                    "errors": " | ".join(span["errors"]),
                }
            )


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Extract useful information from Jaeger trace JSON."
    )

    parser.add_argument(
        "input_file",
        type=Path,
        help="Path to the Jaeger trace JSON file.",
    )

    parser.add_argument(
        "--csv",
        type=Path,
        default=Path("jaeger_trace_summary.csv"),
        help="Output CSV path.",
    )

    parser.add_argument(
        "--top",
        type=int,
        default=10,
        help="Number of slowest spans to display.",
    )

    args = parser.parse_args()

    try:
        trace_json = load_json(args.input_file)
        spans = extract_trace_data(trace_json)

        print_summary(spans, top_n=args.top)
        save_csv(spans, args.csv)

        print(f"\nCSV report created: {args.csv.resolve()}")

    except RuntimeError as error:
        print(f"Error: {error}")
        raise SystemExit(1)


if __name__ == "__main__":
    main()
